@model KX_Project.Models.Product
@{
    ViewData["Title"] = "Xóa Sản Phẩm";
}

<div class="section-header">
    <h2 class="section-title" style="color: #e8000d;">Xóa Sản Phẩm</h2>
    <p class="section-subtitle">Bạn có chắc chắn muốn xóa sản phẩm này không?</p>
</div>

<div class="sidebar-widget" style="border-color: rgba(255, 63, 97, 0.3); background: linear-gradient(135deg, #fff 0%, #fff5f6 100%);">
    <div class="d-flex align-items-center gap-4 mb-4">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="@Model.Name" style="width: 120px; height: 120px; object-fit: cover; border-radius: 12px; border: 1px solid var(--clr-border);" />
        }
        <div>
            <h3 class="widget-title" style="font-size: 1.5rem;">@Model.Name</h3>
            <div class="product-card__category mb-2">@Model.Category?.Name</div>
            <div class="price--current">@Model.Price.ToString("N0") ₫</div>
        </div>
    </div>
    
    <div class="alert alert-danger" style="background: rgba(255, 63, 97, 0.1); border: 1px solid rgba(255, 63, 97, 0.2); color: #e8000d; border-radius: var(--radius-sm);">
        <i class="fas fa-exclamation-triangle me-2"></i> Hành động này không thể hoàn tác! Sản phẩm sẽ bị xóa vĩnh viễn khỏi cơ sở dữ liệu.
    </div>

    <form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post" class="mt-4 pt-3 border-top">
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn--primary" style="background: linear-gradient(135deg, #ff3f61, #cc3a5a);">
                <i class="fas fa-trash-alt"></i> Xác Nhận Xóa
            </button>
            <a asp-action="Index" class="btn btn--secondary">Hủy Bỏ</a>
        </div>
    </form>
</div>