@model KX_Project.Models.Product
@{
    ViewData["Title"] = "Xóa sản phẩm";
}

<style>
    .admin-card {
        background: #fff;
        border-radius: 1.1rem;
        box-shadow: 0 4px 32px rgba(91,79,255,0.1);
        padding: 2.5rem;
        margin-top: 2rem;
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
        text-align: center;
    }
    .admin-card h2 {
        font-weight: 800;
        margin-bottom: 0.5rem;
        color: #e8000d;
    }
    .product-info-box {
        background: #f8fafc;
        border: 1px solid rgba(100,110,180,0.1);
        border-radius: 0.8rem;
        padding: 1.5rem;
        margin: 1.5rem 0;
        text-align: left;
    }
    .info-row {
        margin-bottom: 0.75rem;
        font-size: 1rem;
    }
    .info-label {
        font-weight: 700;
        color: #5a6282;
        width: 120px;
        display: inline-block;
    }
    .btn-danger-custom {
        background: linear-gradient(135deg, #ff3f61, #e8000d);
        border: none;
        border-radius: 3rem;
        padding: 0.75rem 2.5rem;
        font-weight: 700;
        color: white;
        box-shadow: 0 4px 15px rgba(255, 63, 97, 0.3);
        transition: transform 0.3s ease;
    }
    .btn-danger-custom:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(255, 63, 97, 0.4);
        color: white;
    }
    .btn-secondary {
        border: 2px solid #e2e8f0;
        background: transparent;
        color: #475569;
        border-radius: 3rem;
        padding: 0.7rem 2.5rem;
        font-weight: 600;
        margin-right: 1rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        transition: all 0.2s;
    }
    .btn-secondary:hover {
        background: #f1f5f9;
        color: #1e293b;
    }
    .warning-icon {
        font-size: 4rem;
        color: #ff3f61;
        margin-bottom: 1rem;
    }
</style>

<div class="container pb-5">
    <div class="admin-card">
        <i class="fa-solid fa-triangle-exclamation warning-icon"></i>
        <h2>Xác nhận xóa sản phẩm</h2>
        <p class="text-muted">Bạn có chắc chắn muốn xóa vĩnh viễn sản phẩm này không? Hành động này không thể hoàn tác.</p>
        
        <div class="product-info-box">
            <div class="info-row">
                <span class="info-label">Tên sản phẩm:</span> 
                <span class="fw-bold text-dark">@Model.Name</span>
            </div>
            <div class="info-row">
                <span class="info-label">Giá bán:</span> 
                <span class="text-danger fw-bold">@Model.Price.ToString("#,##0")₫</span>
            </div>
            <div class="info-row mb-0">
                <span class="info-label align-top">Mô tả:</span> 
                <span class="text-muted d-inline-block" style="max-width: calc(100% - 130px);">@Model.Description</span>
            </div>
        </div>
        
        <form asp-action="DeleteConfirmed" method="post" class="mt-4">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex justify-content-center">
                <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                <button type="submit" class="btn btn-danger-custom">Xóa sản phẩm</button>
            </div>
        </form>
    </div>
</div>