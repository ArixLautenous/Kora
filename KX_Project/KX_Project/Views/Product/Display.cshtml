@model KX_Project.Models.Product
@{
    ViewData["Title"] = Model.Name;
}

<style>
    .breadcrumb {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.9rem;
        color: var(--clr-text-muted);
        margin-bottom: 1.5rem;
    }
    .breadcrumb a {
        color: var(--clr-primary);
        text-decoration: none;
    }
    .breadcrumb a:hover {
        color: var(--clr-primary-h);
    }
    .breadcrumb span {
        color: var(--clr-text-dim);
    }
    
    .product-detail-card {
        background: var(--clr-surface);
        border-radius: 1.5rem;
        box-shadow: 0 4px 24px rgba(91, 79, 255, 0.08);
        padding: 0;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
        margin-bottom: 3rem;
        overflow: hidden;
    }

    .product-detail__img-wrap {
        background: #f8f9fa;
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100%;
        width: 100%;
    }
    
    .product-detail__img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .product-detail__info {
        padding: 3rem 3rem 3rem 2rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .product-detail__category {
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--clr-primary);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.5rem;
    }

    .product-detail__title {
        font-size: 2.2rem;
        font-weight: 800;
        color: var(--clr-text);
        line-height: 1.2;
        margin-bottom: 0.8rem;
    }

    .product-detail__rating {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
    }
    .product-detail__rating .stars {
        color: var(--clr-gold);
    }
    .product-detail__rating .reviews {
        color: var(--clr-text-muted);
    }

    .product-detail__price-wrap {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1rem;
    }
    .product-detail__price {
        font-size: 2.5rem;
        font-weight: 800;
        color: #e8000d;
        letter-spacing: -0.02em;
    }
    .product-detail__price-old {
        font-size: 1.1rem;
        color: var(--clr-text-dim);
        text-decoration: line-through;
    }
    .product-detail__discount {
        background: rgba(255, 63, 97, 0.1);
        color: var(--clr-accent);
        padding: 0.2rem 0.6rem;
        border-radius: 2rem;
        font-size: 0.85rem;
        font-weight: 700;
    }

    .product-detail__status {
        color: #00a89e;
        font-size: 0.9rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        margin-bottom: 1.5rem;
    }

    .product-detail__desc {
        font-size: 0.95rem;
        line-height: 1.6;
        color: var(--clr-text-muted);
        margin-bottom: 2rem;
    }

    .specs-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 2rem;
    }
    .specs-table th {
        text-align: left;
        padding: 0.8rem 0;
        border-bottom: 1px solid var(--clr-border);
        color: var(--clr-text);
        font-weight: 600;
        font-size: 0.95rem;
        width: 35%;
    }
    .specs-table td {
        padding: 0.8rem 0;
        border-bottom: 1px solid var(--clr-border);
        color: var(--clr-text-muted);
        font-size: 0.95rem;
    }

    .product-detail__action {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .quantity-selector {
        display: flex;
        align-items: center;
        border: 1px solid var(--clr-border);
        border-radius: 0.5rem;
        overflow: hidden;
    }
    .quantity-selector button {
        width: 40px;
        height: 44px;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        color: var(--clr-text);
        transition: background 0.2s;
    }
    .quantity-selector button:hover {
        background: var(--clr-surface-2);
    }
    .quantity-selector input {
        width: 50px;
        height: 44px;
        border: none;
        border-left: 1px solid var(--clr-border);
        border-right: 1px solid var(--clr-border);
        text-align: center;
        font-weight: 600;
        font-size: 1rem;
    }
    .quantity-selector input:focus {
        outline: none;
    }

    .btn-cart {
        flex: 1;
        height: 44px;
        border-radius: 0.5rem;
        font-size: 1rem;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        color: var(--clr-primary);
        font-weight: 600;
        font-size: 0.9rem;
        transition: gap 0.2s;
    }
    .back-link:hover {
        gap: 0.6rem;
    }

    @@media (max-width: 900px) {
        .product-detail-card {
            grid-template-columns: 1fr;
            gap: 2rem;
            padding: 1.5rem;
        }
        .product-detail__img-wrap {
            max-height: 400px;
        }
    }
</style>

<div class="breadcrumb">
    <a asp-action="Index">Trang chủ</a> <span>/</span> 
    <a asp-action="Index">Sản phẩm</a> <span>/</span> 
    <span>@Model.Name</span>
</div>

<div class="product-detail-card">
    <div class="product-detail__img-wrap">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="@Model.Name" class="product-detail__img" />
        }
        else
        {
            <div style="padding: 4rem; color: var(--clr-text-dim);">
                <i class="fas fa-image fa-5x"></i>
            </div>
        }
    </div>

    <div class="product-detail__info">
        <div class="product-detail__category">@Model.Category?.Name</div>
        <h1 class="product-detail__title">@Model.Name</h1>
        
        <div class="product-detail__rating">
            <div class="stars">
                <i class="fas fa-star"></i>
                <i class="fas fa-star"></i>
                <i class="fas fa-star"></i>
                <i class="fas fa-star"></i>
                <i class="fas fa-star-half-alt"></i>
            </div>
            <span class="reviews">4.5 (312 đánh giá)</span>
        </div>

        <div class="product-detail__price-wrap">
            <div class="product-detail__price">@Model.Price.ToString("N0")đ</div>
            <div class="product-detail__price-old">@((Model.Price * 1.15m).ToString("N0"))đ</div>
            <div class="product-detail__discount">-13%</div>
        </div>

        <div class="product-detail__status">
            <i class="fas fa-check-circle"></i> Còn hàng – Giao hàng trong 1-2 ngày
        </div>

        <p class="product-detail__desc">
            @Model.Description
        </p>

        @if (!string.IsNullOrEmpty(Model.Processor) || !string.IsNullOrEmpty(Model.Screen) || !string.IsNullOrEmpty(Model.Camera) || !string.IsNullOrEmpty(Model.Battery) || !string.IsNullOrEmpty(Model.Storage) || !string.IsNullOrEmpty(Model.Os) || !string.IsNullOrEmpty(Model.Ram) || !string.IsNullOrEmpty(Model.GraphicsCard) || !string.IsNullOrEmpty(Model.Weight) || !string.IsNullOrEmpty(Model.Connectivity) || !string.IsNullOrEmpty(Model.FrequencyResponse) || !string.IsNullOrEmpty(Model.Impedance) || !string.IsNullOrEmpty(Model.Sensitivity) || !string.IsNullOrEmpty(Model.AudioFormat))
        {
            <h4 style="margin-bottom: 1rem; font-size: 1.1rem; font-weight: 700;">Thông số kỹ thuật</h4>
            <table class="specs-table">
                <tbody>
                    @if (!string.IsNullOrEmpty(Model.Processor)) { <tr><th>Chip / Vi xử lý</th><td>@Model.Processor</td></tr> }
                    @if (!string.IsNullOrEmpty(Model.Ram)) { <tr><th>RAM</th><td>@Model.Ram</td></tr> }
                    @if (!string.IsNullOrEmpty(Model.Screen)) { <tr><th>Màn hình</th><td>@Model.Screen</td></tr> }
                    @if (!string.IsNullOrEmpty(Model.GraphicsCard)) { <tr><th>Card đồ họa (VGA)</th><td>@Model.GraphicsCard</td></tr> }
                    @if (!string.IsNullOrEmpty(Model.Camera)) { <tr><th>Camera</th><td>@Model.Camera</td></tr> }
                    @if (!string.IsNullOrEmpty(Model.Storage)) { <tr><th>Lưu trữ</th><td>@Model.Storage</td></tr> }
                    @if (!string.IsNullOrEmpty(Model.Os)) { <tr><th>Hệ điều hành</th><td>@Model.Os</td></tr> }
                    @if (!string.IsNullOrEmpty(Model.Battery)) { <tr><th>Pin</th><td>@Model.Battery</td></tr> }
                    
                    @if (!string.IsNullOrEmpty(Model.Connectivity)) { <tr><th>Kết nối</th><td>@Model.Connectivity</td></tr> }
                    @if (!string.IsNullOrEmpty(Model.FrequencyResponse)) { <tr><th>Tần số đáp ứng</th><td>@Model.FrequencyResponse</td></tr> }
                    @if (!string.IsNullOrEmpty(Model.Impedance)) { <tr><th>Trở kháng</th><td>@Model.Impedance</td></tr> }
                    @if (!string.IsNullOrEmpty(Model.Sensitivity)) { <tr><th>Độ nhạy</th><td>@Model.Sensitivity</td></tr> }
                    @if (!string.IsNullOrEmpty(Model.AudioFormat)) { <tr><th>Định dạng âm thanh</th><td>@Model.AudioFormat</td></tr> }
                    
                    @if (!string.IsNullOrEmpty(Model.Weight)) { <tr><th>Trọng lượng</th><td>@Model.Weight</td></tr> }
                </tbody>
            </table>
        }

        <div class="product-detail__action">
            <form asp-controller="Cart" asp-action="AddToCart" method="post" class="d-flex w-100 gap-3">
                <input type="hidden" name="productId" value="@Model.Id" />
                <div class="quantity-selector">
                    <button type="button" onclick="var input = this.nextElementSibling; input.value = Math.max(1, parseInt(input.value) - 1);">-</button>
                    <input type="text" name="quantity" value="1" readonly style="width: 50px; text-align: center;" />
                    <button type="button" onclick="var input = this.previousElementSibling; input.value = parseInt(input.value) + 1;">+</button>
                </div>
                <button type="submit" class="btn btn--primary btn-cart">
                    <i class="fas fa-shopping-cart"></i> Thêm vào giỏ hàng
                </button>
            </form>
        </div>

        <a asp-action="Index" class="back-link">
            <i class="fas fa-arrow-left"></i> Tiếp tục mua sắm
        </a>
        
        @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
        {
            <div class="mt-3 d-flex gap-2">
                 <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn--secondary" style="padding: 0.4rem 1rem; font-size: 0.85rem;"><i class="fas fa-edit"></i> Sửa</a>
                 <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn--secondary" style="padding: 0.4rem 1rem; font-size: 0.85rem; color: #e8000d; border-color: rgba(232,0,13,0.2);"><i class="fas fa-trash"></i> Xóa</a>
            </div>
        }
    </div>
</div>

<div class="section-header" style="margin-top: 4rem;">
    <h3 class="section-title" style="font-size: 1.4rem;">Sản phẩm liên quan</h3>
</div>
<div class="product-grid" style="margin-bottom: 4rem;">
    <!-- Khung chờ sản phẩm liên quan (Hiển thị 4 cột) -->
</div>