@model IEnumerable<KX_Project.Models.CartItem>

@{
    ViewData["Title"] = "Giỏ Hàng Của Bạn";
}

<div class="section-header">
    <h2 class="section-title">Giỏ Hàng Của Bạn</h2>
    <p class="section-subtitle">Xem lại các sản phẩm bạn đã chọn trước khi thanh toán</p>
</div>

@if (!Model.Any())
{
    <div class="sidebar-widget text-center py-5">
        <i class="fa-solid fa-cart-arrow-down fa-4x text-muted mb-3"></i>
        <h4>Giỏ hàng của bạn đang trống</h4>
        <p class="text-muted mb-4">Hãy quay lại trang chủ và chọn cho mình những món đồ ưng ý nhé!</p>
        <a asp-controller="Product" asp-action="Index" class="btn btn--primary">
            <i class="fa-solid fa-arrow-left me-2"></i> Tiếp tục mua sắm
        </a>
    </div>
}
else
{
    <div class="row">
        <div class="col-lg-8">
            <div class="sidebar-widget">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Sản phẩm</th>
                            <th>Đơn giá</th>
                            <th>Số lượng</th>
                            <th>Thành tiền</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <img src="@item.Product.ImageUrl" alt="@item.Product.Name" style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px; margin-right: 15px;" />
                                        <div>
                                            <h6 class="mb-0 font-weight-bold">@item.Product.Name</h6>
                                            <small class="text-muted">@item.Product.Category?.Name</small>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="text-danger fw-bold">@item.Product.Price.ToString("N0") ₫</span></td>
                                <td>
                                    <form asp-action="UpdateQuantity" method="post" class="d-flex align-items-center" style="max-width: 130px;">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <div class="input-group input-group-sm shadow-sm rounded">
                                            <button class="btn btn-outline-secondary px-2 border-end-0" type="button" onclick="this.parentNode.querySelector('input[type=number]').stepDown(); this.closest('form').submit();">
                                                <i class="fa-solid fa-minus"></i>
                                            </button>
                                            <input type="number" name="quantity" value="@item.Quantity" min="1" class="form-control text-center px-1 fw-bold border-secondary border-start-0 border-end-0" style="appearance: textfield;" onchange="this.closest('form').submit();" />
                                            <button class="btn btn-outline-secondary px-2 border-start-0" type="button" onclick="this.parentNode.querySelector('input[type=number]').stepUp(); this.closest('form').submit();">
                                                <i class="fa-solid fa-plus"></i>
                                            </button>
                                        </div>
                                    </form>
                                </td>
                                <td>
                                    <span class="text-danger fw-bold">@((item.Product.Price * item.Quantity).ToString("N0")) ₫</span>
                                </td>
                                <td>
                                    <form asp-action="RemoveFromCart" asp-route-id="@item.Id" method="post">
                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                            <i class="fa-solid fa-trash"></i> Xóa
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="col-lg-4 mt-4 mt-lg-0">
            <div class="sidebar-widget">
                <h4 class="widget-title mb-4">Tóm tắt đơn hàng</h4>
                <div class="d-flex justify-content-between mb-3">
                    <span>Tổng tiền sản phẩm</span>
                    <span class="fw-bold">@Model.Sum(i => i.Product.Price * i.Quantity).ToString("N0") ₫</span>
                </div>
                <div class="d-flex justify-content-between mb-3">
                    <span>Phí giao hàng</span>
                    <span class="text-success fw-bold">Miễn phí</span>
                </div>
                <hr />
                <div class="d-flex justify-content-between mb-4">
                    <span class="fs-5 fw-bold">Tổng thanh toán</span>
                    <span class="fs-5 fw-bold text-danger">@Model.Sum(i => i.Product.Price * i.Quantity).ToString("N0") ₫</span>
                </div>
                <a asp-controller="Order" asp-action="Checkout" class="btn btn--primary btn--full py-3" style="font-size: 1.1rem;">
                    Tiến hành Đặt hàng <i class="fa-solid fa-arrow-right ms-2"></i>
                </a>
                <a asp-controller="Product" asp-action="Index" class="btn btn--secondary btn--full mt-2">
                    Tiếp tục mua sắm
                </a>
            </div>
        </div>
    </div>
}
