@model IEnumerable<KX_Project.Models.Product>

<div class="section-header">
    <h2 class="section-title">Sản phẩm</h2>
    <p class="section-subtitle">Khám phá bộ sưu tập của chúng tôi</p>
</div>

@if (User.IsInRole("Admin") || User.IsInRole("Staff"))
{
    <div class="mb-4">
        <a asp-action="Add" class="btn btn--primary">
            <i class="fas fa-plus"></i> Thêm sản phẩm mới
        </a>
    </div>
}

<div class="product-grid">
    @foreach (var product in Model)
    {
        <div class="product-card">
            <div class="product-card__badge">MỚI</div>
            <div class="product-card__img-wrap">
                <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "/images/default-placeholder.jpg" : product.ImageUrl)" alt="@product.Name" class="product-card__img" />
                <div class="product-card__overlay">
                    <a asp-action="Display" asp-route-id="@product.Id" class="overlay-btn">
                        <i class="fas fa-eye"></i> Xem chi tiết
                    </a>
                </div>
            </div>
            <div class="product-card__body">
                <div class="product-card__category">@product.Category?.Name</div>
                <a asp-action="Display" asp-route-id="@product.Id" class="product-card__name-link">
                    <h3 class="product-card__name">@product.Name</h3>
                </a>
                <p class="product-card__desc">@product.Description</p>
                    <div class="product-card__footer">
                        <div class="product-card__price">
                            <span class="price--current">@product.Price.ToString("N0") ₫</span>
                        </div>
                        <div class="d-flex gap-2 align-items-center">
                            <form asp-controller="Cart" asp-action="AddToCart" method="post" class="m-0 p-0 d-inline">
                                <input type="hidden" name="productId" value="@product.Id" />
                                <input type="hidden" name="quantity" value="1" />
                                <button type="submit" class="btn btn--primary" style="padding: 0.4rem 0.8rem; font-size: 0.8rem;">
                                    <i class="fa-solid fa-cart-plus"></i> Thêm
                                </button>
                            </form>
                            @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                            {
                                <div class="product-card__actions">
                                    <a asp-action="Update" asp-route-id="@product.Id" class="btn btn--secondary" style="padding: 0.4rem 0.8rem; font-size: 0.8rem;">Sửa</a>
                                    <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn--secondary" style="padding: 0.4rem 0.8rem; font-size: 0.8rem; color: #ff3f61; border-color: rgba(255, 63, 97, 0.3);">Xóa</a>
                                </div>
                            }
                        </div>
                    </div>
            </div>
        </div>
    }
</div>