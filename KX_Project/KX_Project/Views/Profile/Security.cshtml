@{
    ViewData["Title"] = "Bảo mật tài khoản";
}

<div class="container mt-4" style="max-width: 800px;">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-triangle-exclamation me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Đổi mật khẩu -->
        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                    <h2 class="h5 mb-0"><i class="fa-solid fa-lock text-primary me-2"></i> Đổi mật khẩu</h2>
                </div>
                <div class="card-body p-4">
                    <form asp-action="ChangePassword" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-semibold" for="OldPassword">Mật khẩu hiện tại</label>
                            <input type="password" class="form-control" id="OldPassword" name="OldPassword" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold" for="NewPassword">Mật khẩu mới</label>
                            <input type="password" class="form-control" id="NewPassword" name="NewPassword" required />
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-semibold" for="ConfirmPassword">Xác nhận mật khẩu mới</label>
                            <input type="password" class="form-control" id="ConfirmPassword" name="ConfirmPassword" required />
                        </div>
                        <button type="submit" class="btn btn--primary w-100"><i class="fa-solid fa-key me-1"></i> Cập nhật mật khẩu</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Đổi Email -->
        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                    <h2 class="h5 mb-0"><i class="fa-solid fa-envelope text-primary me-2"></i> Đổi Email</h2>
                </div>
                <div class="card-body p-4">
                    <form asp-action="ChangeEmail" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Email hiện tại</label>
                            <input type="email" class="form-control bg-light" value="@ViewBag.Email" readonly disabled />
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-semibold" for="NewEmail">Email mới</label>
                            <input type="email" class="form-control" id="NewEmail" name="NewEmail" placeholder="Nhập địa chỉ email mới..." required />
                        </div>
                        <button type="submit" class="btn btn--secondary w-100"><i class="fa-solid fa-paper-plane me-1"></i> Cập nhật Email</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
