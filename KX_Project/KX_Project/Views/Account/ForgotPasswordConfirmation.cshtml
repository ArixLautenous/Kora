@{
    ViewData["Title"] = "Đã gửi yêu cầu";
}

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-md-6 col-lg-5">
        <div class="sidebar-widget text-center" style="padding: 3rem; border-radius: 1.5rem;">
            <i class="fa-solid fa-envelope-circle-check fa-4x text-success mb-3"></i>
            <h2 style="font-weight: 800;">Kiểm tra Email</h2>
            <p class="text-muted mb-4">Chúng tôi đã nhận được yêu cầu của bạn. Nếu email tồn tại trong hệ thống, bạn sẽ nhận được một liên kết để đặt lại mật khẩu.</p>

            @if (ViewBag.Token != null && ViewBag.Email != null)
            {
                <div class="alert alert-warning text-start">
                    <strong>Chế độ mô phỏng (Không có SMTP):</strong> <br/>
                    Đây là liên kết đặt lại mật khẩu của bạn:<br/>
                    <a asp-action="ResetPassword" asp-route-email="@ViewBag.Email" asp-route-token="@ViewBag.Token" style="word-break: break-all;">Click vào đây để đặt lại mật khẩu</a>
                </div>
            }

            <a asp-action="Login" class="btn btn--secondary mt-3"><i class="fa-solid fa-arrow-left me-2"></i> Quay lại Đăng nhập</a>
        </div>
    </div>
</div>
