@model KX_Project.Models.Product
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Cập Nhật Sản Phẩm";
}

<div class="section-header">
    <h2 class="section-title">Chỉnh Sửa Sản Phẩm</h2>
    <p class="section-subtitle">Cập nhật thông tin cho sản phẩm: @Model.Name</p>
</div>

<div class="sidebar-widget">
    <form asp-action="Update" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />
        
        <div class="form-group mb-3">
            <label asp-for="Name" class="widget-title">Tên sản phẩm</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="form-group mb-3">
            <label asp-for="Price" class="widget-title">Giá (₫)</label>
            <input asp-for="Price" class="form-control" />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>
        <div class="form-group mb-3">
            <label asp-for="Description" class="widget-title">Mô tả</label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
        <div class="form-group mb-3">
            <label asp-for="CategoryId" class="widget-title">Danh mục</label>
            <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-control"></select>
        </div>

        <hr class="my-4" style="border-color: var(--clr-border);">
        <h4 class="widget-title mb-3" style="color: var(--clr-primary);">Thông số kỹ thuật</h4>
        
        <div class="row" id="specs-container">
            <div class="col-md-6 form-group mb-3 spec-field" data-categories="1,2,5">
                <label asp-for="Processor" class="widget-title">CPU / Chip xử lý</label>
                <input asp-for="Processor" class="form-control" />
            </div>
            <div class="col-md-6 form-group mb-3 spec-field" data-categories="2,5">
                <label asp-for="Ram" class="widget-title">RAM</label>
                <input asp-for="Ram" class="form-control" />
            </div>
            <div class="col-md-6 form-group mb-3 spec-field" data-categories="1,2">
                <label asp-for="Screen" class="widget-title">Màn hình</label>
                <input asp-for="Screen" class="form-control" />
            </div>
            <div class="col-md-6 form-group mb-3 spec-field" data-categories="2,5">
                <label asp-for="GraphicsCard" class="widget-title">Card đồ họa (VGA)</label>
                <input asp-for="GraphicsCard" class="form-control" />
            </div>
            <div class="col-md-6 form-group mb-3 spec-field" data-categories="1">
                <label asp-for="Camera" class="widget-title">Camera</label>
                <input asp-for="Camera" class="form-control" />
            </div>
            <div class="col-md-6 form-group mb-3 spec-field" data-categories="1,2,3">
                <label asp-for="Battery" class="widget-title">Pin</label>
                <input asp-for="Battery" class="form-control" />
            </div>
            <div class="col-md-6 form-group mb-3 spec-field" data-categories="1,2,5">
                <label asp-for="Storage" class="widget-title">Bộ nhớ / Ổ cứng</label>
                <input asp-for="Storage" class="form-control" />
            </div>
            <div class="col-md-6 form-group mb-3 spec-field" data-categories="1,2,5">
                <label asp-for="Os" class="widget-title">Hệ điều hành</label>
                <input asp-for="Os" class="form-control" />
            </div>
            <div class="col-md-6 form-group mb-3 spec-field" data-categories="2,3,5">
                <label asp-for="Weight" class="widget-title">Trọng lượng</label>
                <input asp-for="Weight" class="form-control" />
            </div>

            <!-- Audio Specs -->
            <div class="col-md-6 form-group mb-3 spec-field" data-categories="3">
                <label asp-for="Connectivity" class="widget-title">Kết nối</label>
                <input asp-for="Connectivity" class="form-control" />
            </div>
            <div class="col-md-6 form-group mb-3 spec-field" data-categories="3">
                <label asp-for="FrequencyResponse" class="widget-title">Tần số đáp ứng</label>
                <input asp-for="FrequencyResponse" class="form-control" />
            </div>
            <div class="col-md-6 form-group mb-3 spec-field" data-categories="3">
                <label asp-for="Impedance" class="widget-title">Trở kháng</label>
                <input asp-for="Impedance" class="form-control" />
            </div>
            <div class="col-md-6 form-group mb-3 spec-field" data-categories="3">
                <label asp-for="Sensitivity" class="widget-title">Độ nhạy</label>
                <input asp-for="Sensitivity" class="form-control" />
            </div>
            <div class="col-md-6 form-group mb-3 spec-field" data-categories="3">
                <label asp-for="AudioFormat" class="widget-title">Định dạng hỗ trợ</label>
                <input asp-for="AudioFormat" class="form-control" />
            </div>
        </div>

        <hr class="my-4" style="border-color: var(--clr-border);">
        <div class="form-group mb-4">
            <label asp-for="ImageUrl" class="widget-title">Hình ảnh đại diện</label>
            <input type="file" asp-for="ImageUrl" class="form-control" />
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="mt-2">
                    <img src="@Model.ImageUrl" alt="Current Image" style="max-height: 100px; border-radius: 8px; border: 1px solid var(--clr-border);" />
                    <small class="d-block text-muted mt-1">Ảnh hiện tại (Để trống nếu không muốn đổi)</small>
                </div>
            }
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn--primary">
                <i class="fas fa-save"></i> Cập Nhật
            </button>
            <a asp-action="Index" class="btn btn--secondary">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function updateSpecFields() {
            var categoryId = document.getElementById('CategoryId').value;
            var specFields = document.querySelectorAll('.spec-field');
            
            specFields.forEach(function(field) {
                var categories = field.getAttribute('data-categories').split(',');
                if (categories.includes(categoryId)) {
                    field.style.display = 'block';
                } else {
                    field.style.display = 'none';
                }
            });
        }

        document.getElementById('CategoryId').addEventListener('change', updateSpecFields);
        updateSpecFields(); // Chạy lúc mới load trang
    </script>
}