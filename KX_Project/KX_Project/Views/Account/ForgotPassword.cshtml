@model KX_Project.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-md-6 col-lg-5">
        <div class="sidebar-widget" style="padding: 3rem; border-radius: 1.5rem;">
            <div class="text-center mb-4">
                <i class="fa-solid fa-key fa-4x text-primary mb-3" style="color: var(--clr-primary);"></i>
                <h2 style="font-weight: 800;">Quên mật khẩu</h2>
                <p class="text-muted">Nhập email của bạn để nhận liên kết đặt lại mật khẩu</p>
            </div>

            <form asp-action="ForgotPassword" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 font-weight-bold"></div>

                <div class="form-group mb-4">
                    <label asp-for="Email" class="widget-title">Email đã đăng ký</label>
                    <input asp-for="Email" class="form-control" placeholder="Nhập email của bạn" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn--primary btn--full mb-3" style="height: 50px; font-size: 1.1rem;">
                    <i class="fas fa-paper-plane me-2"></i> Gửi yêu cầu
                </button>
            </form>

            <div class="text-center mt-4 pt-3 border-top">
                <p class="mb-0 text-muted">Nhớ lại mật khẩu? <a asp-action="Login" style="color: var(--clr-primary); font-weight: 600; text-decoration: none;">Đăng nhập</a></p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
