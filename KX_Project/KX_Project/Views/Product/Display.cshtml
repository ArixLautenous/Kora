@model KX_Project.Models.Product
@{
    ViewData["Title"] = "Chi tiết sản phẩm";
    var imgSrc = !string.IsNullOrEmpty(Model.ImageUrl) ? Model.ImageUrl : "https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?w=800&h=600&fit=crop&auto=format";
}

<style>
    .detail-card {
      background: #fff;
      border-radius: 1.1rem;
      box-shadow: 0 4px 32px rgba(91,79,255,0.1);
      overflow: hidden;
      margin-bottom: 2rem;
    }
    .detail-img-wrap {
      position: relative;
      overflow: hidden;
      border-radius: 1.1rem 0 0 1.1rem;
      min-height: 420px;
      background: #f5f6fb;
    }
    .detail-img-wrap img {
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }
    .detail-img-wrap:hover img { transform: scale(1.04); }
    .detail-info { padding: 2.5rem 2rem; }
    .detail-category {
      font-size: 0.75rem; font-weight: 700;
      color: #5b4fff; text-transform: uppercase; letter-spacing: 0.07em;
      margin-bottom: 0.5rem;
    }
    .detail-name { font-size: 1.9rem; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 0.75rem; }
    .detail-price-current { font-size: 1.9rem; font-weight: 800; color: #e8000d; }
    .detail-desc { color: #5a6282; line-height: 1.75; font-size: 0.95rem; margin: 1.25rem 0; }
    .btn-add-cart {
      background: linear-gradient(135deg,#5b4fff,#ff3f61);
      border: 2px solid transparent; color: #fff; border-radius: 3rem;
      height: 48px; padding: 0 1.75rem; font-weight: 700; font-size: 1rem;
      box-shadow: 0 4px 20px rgba(91,79,255,0.35);
      transition: all 0.3s ease;
      display: inline-flex; align-items: center; justify-content: center;
      line-height: 1;
    }
    .btn-add-cart:hover { transform: translateY(-3px); box-shadow: 0 10px 32px rgba(91,79,255,0.5); color:#fff; }
    .btn-back {
      border: 2px solid rgba(91,79,255,0.35); color: #5b4fff;
      border-radius: 3rem; height: 48px; padding: 0 1.75rem;
      font-weight: 600; font-size: 1rem; background: transparent; transition: all 0.25s;
      text-decoration: none; display: inline-flex; align-items: center; justify-content: center;
      line-height: 1;
    }
    .btn-back:hover { background: #5b4fff; color: #fff; border-color: #5b4fff; transform: translateY(-2px); text-decoration: none;}
    .related-card {
      border: 1px solid rgba(100,110,180,0.14); border-radius: 1rem;
      overflow: hidden; background: #fff;
      box-shadow: 0 2px 12px rgba(91,79,255,0.06);
      transition: transform 0.35s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.3s;
      cursor: pointer; text-decoration: none; color: inherit;
    }
    .related-card:hover { transform: translateY(-6px); box-shadow: 0 16px 40px rgba(91,79,255,0.14); color: inherit; }
    .related-img { width:100%; height:160px; object-fit:cover; }
    .related-price { font-weight: 800; color: #e8000d; }

    @@media (max-width: 767px) {
      .detail-img-wrap { min-height: 260px; border-radius: 1.1rem 1.1rem 0 0; }
      .detail-info { padding: 1.5rem; }
      .detail-name { font-size: 1.4rem; }
    }
</style>

<div class="mt-4">
    <div class="detail-card">
      <div class="row g-0">
        <!-- Image -->
        <div class="col-md-6">
          <div class="detail-img-wrap h-100">
            <img src="@imgSrc" alt="@Model.Name" />
          </div>
        </div>
        <!-- Info -->
        <div class="col-md-6">
          <div class="detail-info">
            <div class="detail-category">Danh mục ID: @Model.CategoryId</div>
            <h1 class="detail-name">@Model.Name</h1>

            <div class="mb-3">
              <span class="detail-price-current">@Model.Price.ToString("#,##0")₫</span>
            </div>

            <p class="detail-desc">@Model.Description</p>

            <div class="d-flex align-items-center gap-3 mt-4">
              <button class="btn btn-add-cart">
                <i class="fa-solid fa-cart-shopping me-2"></i>Thêm vào giỏ hàng
              </button>
              <a asp-action="Index" class="btn-back">
                <i class="fa-solid fa-arrow-left me-2"></i>Tiếp tục mua sắm
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ===== RELATED PRODUCTS ===== -->
    <h2 class="fw-bold mb-3 mt-5" style="font-weight:800;font-size:1.4rem">Sản phẩm liên quan</h2>
    <div class="d-flex flex-nowrap overflow-auto gap-3 pb-3 mb-5" style="scrollbar-width: thin; -webkit-overflow-scrolling: touch;">
        @if (ViewBag.RelatedProducts != null)
        {
            foreach (var rp in ViewBag.RelatedProducts as IEnumerable<KX_Project.Models.Product>)
            {
                var rpImgSrc = !string.IsNullOrEmpty(rp.ImageUrl) ? rp.ImageUrl : "https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?w=400&h=280&fit=crop&auto=format";
                <div style="flex: 0 0 auto; width: 240px;">
                    <a asp-action="Display" asp-route-id="@rp.Id" class="related-card d-block text-decoration-none h-100">
                        <img src="@rpImgSrc" alt="@rp.Name" class="related-img" loading="lazy" />
                        <div class="p-3">
                            <div class="text-muted" style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:#5b4fff!important">Danh mục: @rp.CategoryId</div>
                            <div class="fw-bold mt-1 mb-1" style="font-size:.9rem;line-height:1.3;color:#1a1d2e;">@rp.Name</div>
                            <div class="related-price">@rp.Price.ToString("#,##0")₫</div>
                        </div>
                    </a>
                </div>
            }
        }
    </div>
</div>