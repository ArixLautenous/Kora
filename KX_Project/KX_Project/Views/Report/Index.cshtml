@model IEnumerable<KX_Project.Models.Order>

@{
    ViewData["Title"] = "Báo Cáo Doanh Thu";
}

<div class="section-header">
    <h2 class="section-title">Báo Cáo Doanh Thu & Hệ Thống</h2>
    <p class="section-subtitle">Thống kê tổng quan hoạt động kinh doanh (Chỉ dành cho Admin)</p>
</div>

<div class="row mb-5">
    <div class="col-md-4">
        <div class="sidebar-widget text-center py-4" style="border-left: 5px solid var(--clr-primary);">
            <i class="fa-solid fa-boxes-stacked fa-3x text-primary mb-3"></i>
            <h5 class="text-muted mb-1">Tổng Đơn Hàng</h5>
            <h2 class="fw-bold">@ViewBag.TotalOrders</h2>
        </div>
    </div>
    <div class="col-md-4">
        <div class="sidebar-widget text-center py-4" style="border-left: 5px solid #28a745;">
            <i class="fa-solid fa-money-bill-wave fa-3x mb-3" style="color: #28a745;"></i>
            <h5 class="text-muted mb-1">Tổng Doanh Thu</h5>
            <h2 class="fw-bold text-success">@(((decimal)ViewBag.TotalRevenue).ToString("N0")) ₫</h2>
        </div>
    </div>
    <div class="col-md-4">
        <div class="sidebar-widget text-center py-4" style="border-left: 5px solid #ffc107;">
            <i class="fa-solid fa-clock-rotate-left fa-3x text-warning mb-3"></i>
            <h5 class="text-muted mb-1">Đơn Chờ Xử Lý</h5>
            <h2 class="fw-bold text-warning">@ViewBag.PendingOrders</h2>
        </div>
    </div>
</div>

<div class="sidebar-widget">
    <h4 class="widget-title mb-4">10 Đơn hàng gần nhất</h4>
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Mã ĐH</th>
                <th>Khách hàng</th>
                <th>Tổng tiền</th>
                <th>Ngày đặt</th>
                <th>Trạng thái</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td class="fw-bold">#@order.Id</td>
                    <td>@order.User?.Email</td>
                    <td class="text-danger fw-bold">@order.TotalAmount.ToString("N0") ₫</td>
                    <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        @{
                            string badgeClass = order.Status switch {
                                "Pending" => "bg-warning text-dark",
                                "Processing" => "bg-info text-dark",
                                "Shipped" => "bg-primary",
                                "Delivered" => "bg-success",
                                "Cancelled" => "bg-danger",
                                _ => "bg-secondary"
                            };
                        }
                        <span class="badge @badgeClass p-2">@order.Status</span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="text-end mt-3">
        <a asp-controller="Order" asp-action="ManageOrders" class="btn btn-outline-primary">Xem tất cả đơn hàng <i class="fa-solid fa-arrow-right ms-1"></i></a>
    </div>
</div>
