@model KX_Project.Models.Product
@{
    ViewData["Title"] = "Chỉnh sửa sản phẩm";
}

<style>
    .admin-card {
        background: #fff;
        border-radius: 1.1rem;
        box-shadow: 0 4px 32px rgba(91,79,255,0.1);
        padding: 2.5rem;
        margin-top: 2rem;
        max-width: 800px;
        margin-left: auto;
        margin-right: auto;
    }
    .admin-card h2 {
        font-weight: 800;
        margin-bottom: 1.5rem;
        color: #1a1d2e;
    }
    .form-group {
        margin-bottom: 1.25rem;
    }
    .form-label {
        font-weight: 600;
        color: #5a6282;
        margin-bottom: 0.5rem;
    }
    .form-control, .form-select {
        border-radius: 0.5rem;
        border: 1px solid rgba(100,110,180,0.2);
        padding: 0.75rem 1rem;
        font-size: 0.95rem;
        width: 100%;
        display: block;
    }
    .form-control:focus, .form-select:focus {
        border-color: #5b4fff;
        box-shadow: 0 0 0 0.25rem rgba(91,79,255,0.25);
        outline: none;
    }
    .btn-primary {
        background: linear-gradient(135deg, #5b4fff, #4338e0);
        border: none;
        border-radius: 3rem;
        padding: 0.75rem 2.5rem;
        font-weight: 700;
        color: white;
        box-shadow: 0 4px 15px rgba(91,79,255,0.3);
        transition: transform 0.3s ease;
    }
    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(91,79,255,0.4);
        color: white;
    }
    .btn-secondary {
        border: 2px solid #e2e8f0;
        background: transparent;
        color: #475569;
        border-radius: 3rem;
        padding: 0.7rem 2.5rem;
        font-weight: 600;
        margin-right: 1rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        transition: all 0.2s;
    }
    .btn-secondary:hover {
        background: #f1f5f9;
        color: #1e293b;
    }
    .img-preview {
        border-radius: 0.5rem;
        border: 1px solid rgba(100,110,180,0.2);
        padding: 0.25rem;
        background: #f8fafc;
        max-width: 150px;
        max-height: 150px;
        object-fit: contain;
    }
</style>

<div class="container pb-5">
    <div class="admin-card">
        <h2>Chỉnh sửa sản phẩm</h2>
        
        <form asp-action="Update" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ImageUrl" />
            
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="Name" class="form-label">Tên sản phẩm</label>
                        <input asp-for="Name" class="form-control" placeholder="Nhập tên sản phẩm..." />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="Price" class="form-label">Giá bán (VNĐ)</label>
                        <input asp-for="Price" class="form-control" type="number" step="0.01" placeholder="Ví dụ: 150000" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="CategoryId" class="form-label">Danh mục</label>
                        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
                            <option value="">-- Chọn danh mục --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label">Thay đổi hình ảnh</label>
                        <input type="file" name="imageFile" class="form-control" accept="image/*" />
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="mt-3">
                                <label class="form-label" style="font-size:0.85rem">Ảnh hiện tại:</label><br/>
                                <img src="@Model.ImageUrl" alt="Current Image" class="img-preview" />
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Description" class="form-label">Mô tả chi tiết</label>
                <textarea asp-for="Description" class="form-control" rows="4" placeholder="Nhập mô tả sản phẩm..."></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-end mt-4">
                <a asp-action="Index" class="btn btn-secondary">Hủy bỏ</a>
                <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
            </div>
        </form>
    </div>
</div>