@{
    ViewData["Title"] = "Đặt Hàng Thành Công";
    var orderId = ViewBag.OrderId;
}

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-md-8 col-lg-6">
        <div class="sidebar-widget text-center py-5" style="border-radius: 2rem;">
            <div class="mb-4">
                <i class="fa-solid fa-circle-check text-success" style="font-size: 5rem;"></i>
            </div>
            <h2 style="font-weight: 800; margin-bottom: 1rem;">Đặt Hàng Thành Công!</h2>
            <p class="text-muted mb-2" style="font-size: 1.1rem;">Cảm ơn bạn đã mua sắm tại KoraStore.</p>
            <p class="text-muted mb-4">Mã đơn hàng của bạn là: <strong class="text-primary">#@orderId</strong></p>
            
            <p class="mb-5" style="font-size: 0.95rem;">Chúng tôi sẽ sớm liên hệ với bạn để xác nhận đơn hàng và tiến hành giao hàng trong thời gian sớm nhất.</p>

            <a asp-controller="Product" asp-action="Index" class="btn btn--primary px-4 py-2">
                <i class="fa-solid fa-store me-2"></i> Quay lại Cửa hàng
            </a>
        </div>
    </div>
</div>
